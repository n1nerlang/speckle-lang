{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Speckle",
  "scopeName": "source.speckle",
  "fileTypes": ["spk", "speckle"],
  "patterns": [
    {
      "name": "comment.block.speckle",
      "begin": "\\(\\(",
      "end": "\\)\\)"
    },
    {
      "name": "string.quoted.double.speckle",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "name": "constant.character.escape.speckle", "match": "\\\\." }]
    },
    {
      "name": "string.quoted.single.speckle",
      "begin": "'",
      "end": "'",
      "patterns": [{ "name": "constant.character.escape.speckle", "match": "\\\\." }]
    },
    {
      "name": "constant.numeric.speckle",
      "match": "\\b\\d+\\b"
    },
    {
      "name": "support.function.speckle",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
    },
    {
      "name": "variable.other.speckle",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}
